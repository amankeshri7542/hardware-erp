option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production

  aws:elasticbeanstalk:container:nodejs:
    NodeCommand: "node backend/server.js"

files:
  "/etc/systemd/system/pdf-worker.service":
    mode: "000644"
    owner: root
    group: root
    content: |
      [Unit]
      Description=PDF Worker Process
      After=network.target

      [Service]
      Type=simple
      User=webapp
      WorkingDirectory=/var/app/current
      ExecStart=/usr/bin/node /var/app/current/backend/worker.js
      Restart=always
      RestartSec=10
      Environment=NODE_ENV=production
      StandardOutput=journal
      StandardError=journal

      [Install]
      WantedBy=multi-user.target

container_commands:
  01_enable_worker:
    command: "systemctl daemon-reload && systemctl enable pdf-worker.service"
  02_start_worker:
    command: "systemctl restart pdf-worker.service"
