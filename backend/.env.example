# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=hardware-erp-invoices

# Store Config
STORE_NAME=
STORE_ADDRESS=
STORE_PHONE=
STORE_GSTIN=
INVOICE_PREFIX=HW
